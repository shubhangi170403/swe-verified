# Thin assembly Dockerfile for agent-server images.
#
# References pre-built base and builder images that are already in GHCR,
# so the only new layer is the COPY of /agent-server onto the base.
#
# Usage:
#   docker build \
#     --file Dockerfile.agent-layer \
#     --build-arg BASE_IMAGE=ghcr.io/openhands/eval-base:instance-tag \
#     --build-arg BUILDER_IMAGE=ghcr.io/openhands/eval-builder:sdk-sha \
#     --build-arg OPENHANDS_BUILD_GIT_SHA=abc1234... \
#     --tag ghcr.io/openhands/eval-agent-server:final-tag .

ARG BUILDER_IMAGE
ARG BASE_IMAGE

FROM ${BUILDER_IMAGE} AS builder
FROM ${BASE_IMAGE}

ARG USERNAME=openhands
ARG OPENHANDS_BUILD_GIT_SHA=unknown
ENV OPENHANDS_BUILD_GIT_SHA=${OPENHANDS_BUILD_GIT_SHA}

# /agent-server is self-contained: the SDK builder installs uv-managed Python
# into /agent-server/uv-managed-python and the venv symlinks into it. No
# downstream Python-runtime COPY is needed.
COPY --chown=${USERNAME}:${USERNAME} --from=builder /agent-server /agent-server
ENTRYPOINT ["/agent-server/.venv/bin/python", "-m", "openhands.agent_server"]
