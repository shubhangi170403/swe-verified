# Assembly Dockerfile for commit0 agent-server images.
#
# Commit0 base images are raw upstream benchmark images (e.g. Ubuntu 22.04)
# that lack the runtime packages and user setup that the SDK's
# base-image-minimal target normally provides.  This Dockerfile layers those
# onto the real upstream commit0 base before copying the agent-server payload.
#
# Usage:
#   docker build \
#     --file Dockerfile.agent-layer-commit0 \
#     --build-arg BASE_IMAGE=docker.io/wentingzhao/tinydb:v0 \
#     --build-arg BUILDER_IMAGE=ghcr.io/openhands/eval-builder:sdk-sha \
#     --build-arg OPENHANDS_BUILD_GIT_SHA=abc1234... \
#     --tag ghcr.io/openhands/eval-agent-server:final-tag .

ARG BUILDER_IMAGE
ARG BASE_IMAGE

FROM ${BUILDER_IMAGE} AS builder
FROM ${BASE_IMAGE}

ARG USERNAME=openhands
ARG UID=10001
ARG GID=10001
ARG OPENHANDS_BUILD_GIT_SHA=unknown
ENV OPENHANDS_BUILD_GIT_SHA=${OPENHANDS_BUILD_GIT_SHA}

# Reuse the same uv binary the SDK builder was built with, so the version
# stays in sync automatically when the builder image is updated.
COPY --from=builder /bin/uv /bin/uvx /bin/

# Commit0 images are built from the raw upstream benchmark bases, so they are
# missing the core runtime packages that the SDK's base-image-minimal target
# normally installs (tmux, git, build tools, etc.).
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        bash ca-certificates curl wget sudo apt-utils git jq tmux build-essential \
        coreutils util-linux procps findutils grep sed \
        apt-transport-https gnupg lsb-release; \
    (getent group ${GID} || groupadd -g ${GID} ${USERNAME}); \
    (id -u ${USERNAME} >/dev/null 2>&1 || useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME}); \
    usermod -aG sudo ${USERNAME}; \
    echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers; \
    mkdir -p /home/${USERNAME}/.cache /workspace/project; \
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME} /workspace; \
    rm -rf /var/lib/apt/lists/*

# Install ACP CLIs into a dedicated Node 22 prefix so commit0 source images can
# launch Gemini/Claude/Codex ACP without clobbering repo-specific Node installs.
ENV ACP_NODE_DIR=/opt/acp-node
RUN set -eux; \
    ARCH=$(dpkg --print-architecture); \
    case "$ARCH" in \
      amd64) NARCH=x64; NODE_SHA256=69b09dba5c8dcb05c4e4273a4340db1005abeafe3927efda2bc5b249e80437ec;; \
      arm64) NARCH=arm64; NODE_SHA256=08bfbf538bad0e8cbb0269f0173cca28d705874a67a22f60b57d99dc99e30050;; \
      *) echo "Unsupported architecture for ACP Node install: $ARCH" >&2; exit 1;; \
    esac; \
    NODE_TARBALL="/tmp/node-v22.14.0-linux-${NARCH}.tar.xz"; \
    mkdir -p "$ACP_NODE_DIR"; \
    curl -fsSL "https://nodejs.org/dist/v22.14.0/node-v22.14.0-linux-${NARCH}.tar.xz" -o "$NODE_TARBALL"; \
    echo "$NODE_SHA256  $NODE_TARBALL" | sha256sum -c -; \
    tar -xJ --strip-components=1 -C "$ACP_NODE_DIR" -f "$NODE_TARBALL"; \
    rm -f "$NODE_TARBALL"; \
    PATH="$ACP_NODE_DIR/bin:$PATH"; \
    node --version; \
    npm install -g \
      @agentclientprotocol/claude-agent-acp@0.30.0 \
      @zed-industries/codex-acp@0.15.0 \
      @google/gemini-cli@0.38.0; \
    for bin in claude-agent-acp codex-acp gemini; do \
      if [ -e "$ACP_NODE_DIR/bin/$bin" ]; then \
        printf '#!/bin/sh\nPATH="%s/bin:$PATH" exec "%s/bin/%s" "$@"\n' \
          "$ACP_NODE_DIR" "$ACP_NODE_DIR" "$bin" \
          > /usr/local/bin/"$bin"; \
        chmod +x /usr/local/bin/"$bin"; \
      fi; \
    done

ENV HOME=/home/${USERNAME}
ENV PIP_CACHE_DIR=/home/${USERNAME}/.cache/pip
ENV UV_CACHE_DIR=/home/${USERNAME}/.cache/uv
ENV PATH=/home/${USERNAME}/.local/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8
ENV OH_ENABLE_VNC=false
ENV LOG_JSON=true

# /agent-server is self-contained: the SDK builder installs uv-managed Python
# into /agent-server/uv-managed-python and the venv symlinks into it. No
# downstream Python-runtime COPY is needed.
COPY --chown=${USERNAME}:${USERNAME} --from=builder /agent-server /agent-server
WORKDIR /
USER ${USERNAME}
ENTRYPOINT ["/agent-server/.venv/bin/python", "-m", "openhands.agent_server"]
